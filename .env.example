# ── ml-serve configuration ──────────────────────────────────
# All variables are prefixed with ML_SERVE_

# Application
ML_SERVE_APP_NAME=ml-serve
ML_SERVE_APP_VERSION=0.1.0
ML_SERVE_LOG_LEVEL=INFO                # DEBUG, INFO, WARNING, ERROR

# Model
ML_SERVE_MODEL_NAME=sentiment          # registered model name

# Redis (used for rate limiting)
ML_SERVE_REDIS_URL=redis://localhost:6379/0

# Rate limiting
ML_SERVE_RATE_LIMIT_REQUESTS=100       # max requests per window
ML_SERVE_RATE_LIMIT_WINDOW=60          # window size in seconds

# A/B testing
ML_SERVE_AB_TEST_SPLIT=0.5             # traffic fraction routed to variant A

# Auth — comma-separated API keys, empty = no auth
ML_SERVE_API_KEYS=[]

# Observability
ML_SERVE_PROMETHEUS_ENABLED=true
